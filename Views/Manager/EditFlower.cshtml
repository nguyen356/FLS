@model FlowerShop.Models.Flowerdb
@{
    ViewData["Title"] = "Edit Flower";
}

<div class="container" style="max-width: 600px; padding: 2rem 0;">
    <h2 class="section-title">✏️ Edit @Model.Name</h2>
    
    <form asp-action="EditFlower" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="form-group mb-3">
            <label asp-for="Name" class="form-label">Flower Name</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="form-group mb-3>
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>