@model FlowerShop.Models.Flowerdb
@{
    ViewData["Title"] = "Add Flower";
}

<div class="container" style="max-width: 600px; padding: 2rem 0;">
    <h2 class="section-title">➕ Add New Flower</h2>

    @if (!ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary()
        </div>
    }

    <form asp-action="AddFlower" method="post">
        <div class="form-group mb-3">
            <label asp-for="Name" class="form-label">Flower Name</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="row">
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Price" class="form-label">Price ($)</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
            </div>
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Stock" class="form-label">Stock</label>
                <input asp-for="Stock" class="form-control" type="number" />
            </div>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Category" class="form-label">Category</label>
            <input asp-for="Category" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label asp-for="ImageUrl" class="form-label">Image URL (optional)</label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/flower.jpg" />
            <small class="text-muted">Use Unsplash: https://unsplash.com/s/photos/flowers</small>
        </div>
        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a href="/Manager/Inventory" class="btn btn-secondary me-md-2">Cancel</a>
            <button type="submit" class="btn" style="background: var(--primary-color); color: white;">Add Flower</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}