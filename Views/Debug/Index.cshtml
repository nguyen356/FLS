<h1>🔍 Debug Info</h1>

<div class="card">
    <h3>Database</h3>
    <p>Total Users: <strong>@Model.UsersCount</strong></p>
    <p>Admin Exists: <strong>@Model.AdminExists</strong></p>
    <p>Admin Role: <strong>@Model.AdminRole</strong></p>
    <p>First User: <strong>@Model.FirstUser</strong></p>
</div>

@if (!Model.AdminExists)
{
    <div class="alert alert-danger mt-3">
        <strong>❌ NO ADMIN USER!</strong><br>
        Go to MongoDB Atlas → FlowerShop → users → Insert admin document
    </div>
}

<a href="/Account/Login" class="btn btn-primary mt-3">Test Login</a>