@{
    var flowers = ViewBag.Flowers as List<FlowerShop.Models.Flowerdb> ?? new();
}

<section class="flowers-grid">
    @foreach (var flower in flowers.Take(6))
    {
        <div class="flower-card">
            <img src="@flower.ImageUrl" class="flower-image" alt="@flower.Name" />
            <div class="flower-info">
                <h3>@flower.Name</h3>
                <span class="category-badge">@flower.Category</span>
                <p>@flower.Description</p>
                <div class="price-stock">
                    <span class="price">$@flower.Price</span>
                    <span class="stock">@flower.Stock left</span>
                </div>
                <a href="/Home/FlowerDetail/@flower.Id" class="btn">Buy Now</a>
            </div>
        </div>
    }
</section>